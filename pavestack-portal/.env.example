# Environment variables read by the portal build (Vite exposes anything
# prefixed VITE_ to client code via import.meta.env). Copy to .env.local
# for local dev - Vite loads that automatically and it's gitignored.

# Base URL of the pave-api backend this portal talks to. Defaults to
# http://localhost:8787/api/v1 if unset (see src/lib/api.ts).
VITE_API_BASE_URL=http://localhost:8787/api/v1

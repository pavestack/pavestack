{
  "name": "pavestack-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate-catalog": "node scripts/generate-catalog.mjs",
    "dev": "npm run generate-catalog && vite --host 0.0.0.0",
    "build": "npm run generate-catalog && tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc --noEmit",
    "test": "./node_modules/.bin/vitest run"
  },
  "dependencies": {
    "js-yaml": "^4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "^3.0.5"
  }
}

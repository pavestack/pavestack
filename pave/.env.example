# Environment variables read by `pave-api` (cmd/pave-api/main.go).
# Copy to .env and source it, or export these directly, before running
# `make pave-api && ./bin/pave-api`. None of these are read from a .env
# file automatically - pave-api uses plain os.Getenv, no dotenv loader.

# Path to the pavestack monorepo checkout pave-api should scaffold
# services into and open GitOps PRs against. Defaults to auto-detected
# workspace root (see internal/workspace) if unset.
PAVE_API_REPO_ROOT=

# Port pave-api listens on.
PAVE_API_PORT=8787

# When true (the default - never change it for a public/demo deployment),
# pave-api scaffolds services and writes GitOps manifests for real but
# skips the final `git push` / `gh pr create` step. Set to "false" only
# for an operator-controlled instance that should open real PRs.
PAVE_API_DRY_RUN=true

# CORS origin allowed to call this API. Must match the portal's origin
# exactly (e.g. http://localhost:5173 for local dev) - "*" is rejected
# once cookie-based auth is in use, since credentialed CORS forbids a
# wildcard origin.
PAVE_API_CORS_ORIGIN=http://localhost:5173

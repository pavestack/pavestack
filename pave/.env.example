# Environment variables read by `pave-api` (cmd/pave-api/main.go).
# Copy to .env and source it, or export these directly, before running
# `make pave-api && ./bin/pave-api`. None of these are read from a .env
# file automatically - pave-api uses plain os.Getenv, no dotenv loader.

# Path to the pavestack monorepo checkout pave-api should scaffold
# services into and open GitOps PRs against. Defaults to auto-detected
# workspace root (see internal/workspace) if unset.
PAVE_API_REPO_ROOT=

# Port pave-api listens on.
PAVE_API_PORT=8787

# When true (the default - never change it for a public/demo deployment),
# pave-api scaffolds services and writes GitOps manifests for real but
# skips the final `git push` / `gh pr create` step. Set to "false" only
# for an operator-controlled instance that should open real PRs.
PAVE_API_DRY_RUN=true

# CORS origin allowed to call this API. Must match the portal's origin
# exactly (e.g. http://localhost:5173 for local dev) - "*" is rejected
# once cookie-based auth is in use, since credentialed CORS forbids a
# wildcard origin.
PAVE_API_CORS_ORIGIN=http://localhost:5173

# Name reported in structured logs and the OTel resource. Rarely needs
# overriding outside of running multiple pave-api instances side by side.
PAVE_API_SERVICE_NAME=pave-api

# zap log level: debug | info | warn | error.
PAVE_API_LOG_LEVEL=info

# OTLP HTTP endpoint (e.g. http://localhost:4318) traces/metrics are
# exported to. Leave unset to run with in-process no-op exporters (no
# collector required for local dev).
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Authentication (see docs/adr/0002-pave-api-authentication.md) ---
#
# pave-api refuses to start unless GitHub OAuth is fully configured below,
# OR PAVE_API_DISABLE_AUTH=true is set explicitly. There is no silent
# "no auth" fallback.

# Set to "true" to run with no authentication on mutating endpoints at
# all. Local dev/CI only - never set this for a network-reachable
# deployment.
PAVE_API_DISABLE_AUTH=

# A GitHub OAuth App's client ID/secret (create one under your GitHub org
# or personal account for local dev: Settings -> Developer settings ->
# OAuth Apps). Callback URL must be
# "${PAVE_API_BASE_URL}/auth/github/callback".
PAVE_API_GITHUB_CLIENT_ID=
PAVE_API_GITHUB_CLIENT_SECRET=

# Random secret pave-api uses to sign session cookies (HMAC-SHA256) -
# generate with e.g. `openssl rand -hex 32`. Rotating it invalidates all
# existing sessions.
PAVE_API_SESSION_SECRET=

# GitHub org whose team membership is checked, and the team slug within
# it required to approve/deny access requests.
PAVE_API_GITHUB_ORG=pavestack
PAVE_API_APPROVER_TEAM=platform

# pave-api's own externally reachable origin (used to build the OAuth
# redirect_uri) and where the browser is sent after login/logout.
PAVE_API_BASE_URL=http://localhost:8787
PAVE_API_PORTAL_URL=http://localhost:5173
